# Copy to .env (this file is the canonical reference; .env is gitignored).
# All keys are prefixed with FLYDOCS_ so they are easy to grep for and
# easy to scope per service.

# ----------------------------------------------------------------------------
# Service
# ----------------------------------------------------------------------------
FLYDOCS_LOG_LEVEL=INFO
FLYDOCS_PORT=8400

# ----------------------------------------------------------------------------
# Persistence
# ----------------------------------------------------------------------------
# Async-SQLAlchemy URL. asyncpg for Postgres, aiosqlite for SQLite (tests).
FLYDOCS_DATABASE_URL=postgresql+asyncpg://idp:idp@localhost:5432/flydocs

# Run alembic upgrade head on startup (set to "false" in production deploys
# that prefer migrating as a separate step).
RUN_MIGRATIONS=true

# ----------------------------------------------------------------------------
# Queue / async jobs
# ----------------------------------------------------------------------------
# Choose ``memory`` (single-process dev), ``postgres`` (default — durable
# outbox + LISTEN/NOTIFY, no extra broker needed since the service already
# runs Postgres), ``redis`` (Redis Streams), or ``kafka`` (production
# fan-out). All adapters live in ``pyfly.eda.adapters``; the picker is
# pyfly's :class:`EdaAutoConfiguration` driven from ``pyfly.yaml``.
FLYDOCS_EDA_ADAPTER=postgres
FLYDOCS_REDIS_URL=redis://localhost:6379/0

# Topic / stream name for job-submitted events.
FLYDOCS_JOBS_TOPIC=flydocs.jobs

# ----------------------------------------------------------------------------
# Multimodal extraction
# ----------------------------------------------------------------------------
# Provider routing for FireflyAgent. Override at deploy time; supports any
# pydantic-ai provider (``openai:gpt-4o``, ``anthropic:claude-sonnet-4-6``,
# ``bedrock:eu.anthropic.claude-sonnet-4-6-v1``, ``openai:gpt-4o@http://mock-llm:8500``).
FLYDOCS_MODEL=anthropic:claude-sonnet-4-6
FLYDOCS_FALLBACK_MODEL=openai:gpt-4o

# Maximum pages per single extraction request. Documents above this go through
# the async API only. The document bytes are sent directly to the multimodal
# LLM -- no local rasterisation, so format is whatever the provider accepts
# (Anthropic supports PDF natively; OpenAI accepts images).
FLYDOCS_MAX_SYNC_PAGES=10
# Cap on total bytes accepted (after base64-decode) in a single submission.
FLYDOCS_MAX_BYTES=33554432

# Per-call timeouts (seconds). Sync requests get the shorter one; async jobs
# retry up to ``JOB_MAX_ATTEMPTS`` times on timeout.
FLYDOCS_SYNC_TIMEOUT_S=60
FLYDOCS_ASYNC_TIMEOUT_S=300
FLYDOCS_JOB_MAX_ATTEMPTS=3

# Optional pre-extraction text rendering. ``none`` (default) sends only the
# binary to the LLM. ``docling`` runs Docling over the document first and
# splices the resulting Markdown into the user prompt ahead of the binary
# so the multimodal LLM can cross-reference layout against a cleaned-up
# textual view -- useful on multilingual scans and long tabular documents.
# Requires the ``docling`` extra (use the ``docling-`` image variant).
# See docs/docling.md.
FLYDOCS_EXTRACTION_TEXT_ANCHOR=none
# Hard ceiling on the anchor length. Truncated on a paragraph boundary
# when in reach, otherwise hard-cut with a visible ``[anchor truncated]``
# sentinel. Set to 0 to silently disable even when the engine is set.
FLYDOCS_EXTRACTION_TEXT_ANCHOR_MAX_CHARS=12000

# Provider credentials are picked up from the standard env vars (OPENAI_API_KEY,
# ANTHROPIC_API_KEY, AWS_*). Set only the ones you need.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# AWS_REGION=eu-west-1

# When using a self-hosted / mock OpenAI-compatible endpoint (for tests):
# OPENAI_BASE_URL=http://mock-llm:8500/v1

# ----------------------------------------------------------------------------
# Webhook delivery
# ----------------------------------------------------------------------------
# Outbound webhook delivery from the job worker uses these defaults.
FLYDOCS_WEBHOOK_TIMEOUT_S=15
FLYDOCS_WEBHOOK_MAX_ATTEMPTS=5

# Optional shared-secret HMAC signing of webhooks (X-Flydocs-Signature header).
# Leave blank to disable.
FLYDOCS_WEBHOOK_HMAC_SECRET=

# ----------------------------------------------------------------------------
# Bbox refinement
# ----------------------------------------------------------------------------
# OCR engine for image-PDFs and raster inputs consumed by the bbox refiner.
#   * ``tesseract`` (default) -- shells out to the local ``tesseract`` binary.
#     The runtime Dockerfile installs it plus common European language packs.
#   * ``docling`` -- IBM Docling's layout-aware pipeline (Heron layout +
#     RapidOCR by default). Surfaces table-cell + reading-order metadata
#     the matcher uses as a tie-break signal. Requires the ``docling``
#     extra (use the ``docling-`` image variant). See docs/docling.md.
#   * ``none`` -- skip OCR; image pages keep the LLM bbox.
FLYDOCS_BBOX_REFINE_OCR_ENGINE=tesseract
# DPI for PDF→image rasterisation. Only used by the Tesseract path;
# Docling rasterises internally.
FLYDOCS_BBOX_REFINE_OCR_DPI=200
# Default Tesseract ``-l`` argument. Also consumed by Docling as the default
# OCR language hint when no per-request ``language_hint`` is supplied.
FLYDOCS_BBOX_REFINE_TESSERACT_LANG=spa+eng
# Strategy that maps each extracted value to OCR/text-layer word indices.
#   * ``hybrid`` (default) -- rapidfuzz first, LLM only for residual.
#   * ``llm`` -- one LLM call per page over every field.
#   * ``fuzzy`` -- rapidfuzz only, no LLM fallback.
FLYDOCS_BBOX_REFINE_MATCHER=hybrid

# ----------------------------------------------------------------------------
# Security (optional -- only used if you front the service with an auth gate)
# ----------------------------------------------------------------------------
# Static API keys that grant access. Comma-separated.
FLYDOCS_API_KEYS=
